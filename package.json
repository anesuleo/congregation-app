{
  "name": "congregation-app",
  "version": "1.0.0",
  "private": true,
  "description": "Congregation management app — mobile (React Native/Expo) + admin dashboard (React)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "yarn workspace @congregation-app/mobile start",
    "admin": "yarn workspace @congregation-app/admin dev",
    "api": "yarn workspace @congregation-app/api dev",
    "lint": "yarn workspaces run lint",
    "typecheck": "yarn workspaces run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  }
}
